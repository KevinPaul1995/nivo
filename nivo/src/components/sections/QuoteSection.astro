---
import QuoteWizard from "../QuoteWizard.jsx";
---

<section class="content-section quote-section" id="cotizacion" aria-labelledby="quote-title" data-parallax-section>
  <div class="section-grid section-grid--split quote-layout">
    <div class="parallax-layer parallax-layer--copy">
      <div class="section-copy">
        <span class="section-eyebrow">Cotización guiada</span>
        <h2 id="quote-title">Calcula un valor inicial en menos de un minuto.</h2>
        <p>
          Responde unas preguntas rápidas sobre tu espacio y recibe un estimado
          para limpieza de casas, oficinas o empresas.
        </p>
      </div>
    </div>

    <div class="parallax-layer parallax-layer--panel">
      <QuoteWizard client:load />
    </div>
  </div>
</section>
