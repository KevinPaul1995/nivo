---
import { faqItems } from "../../data/siteContent";
---

<section class="content-section faq-section" aria-labelledby="faq-title" data-parallax-section>
  <div class="section-grid section-grid--split">
    <div class="parallax-layer parallax-layer--copy">
      <div class="section-copy">
        <span class="section-eyebrow">Preguntas frecuentes</span>
        <h2 id="faq-title">Lo básico para coordinar tu limpieza.</h2>
        <p>Revisa cobertura, materiales, tipos de espacio y datos útiles para recibir una cotización más precisa.</p>
      </div>
    </div>

    <div class="parallax-layer parallax-layer--panel">
      <div class="faq-list">
        {
          faqItems.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
