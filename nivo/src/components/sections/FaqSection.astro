---
import { faqItems } from "../../data/siteContent";
---

<section class="content-section faq-section" aria-labelledby="faq-title">
  <div class="section-grid section-grid--split">
    <div class="section-copy">
      <span class="section-eyebrow">Preguntas frecuentes</span>
      <h2 id="faq-title">Antes de agendar, dejemos claro lo importante.</h2>
      <p>Así evitamos visitas improvisadas, costos confusos o expectativas distintas sobre el alcance del servicio.</p>
    </div>

    <div class="faq-list">
      {
        faqItems.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
