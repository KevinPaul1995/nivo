---
import ParticleHero from "../ParticleHero.jsx";
---

<section class="hero" id="inicio" aria-labelledby="hero-title">
  <ParticleHero client:load />

  <div class="hero__intro-copy">
    <span>NIVO</span>
    <strong>Limpieza profesional</strong>
  </div>

  <div class="hero__section-copy hero__about-copy">
    <span>Ibarra · Atuntaqui · Cotacachi · Otavalo</span>
    <strong>Calidad visible. Coordinación simple.</strong>
  </div>

  <div class="hero__section-copy hero__services-copy">
    <span>Precisión visible</span>
    <strong>Orden que se siente desde la puerta.</strong>
    <p>Baños, cocinas y superficies de alto contacto con revisión final antes de terminar.</p>
  </div>

  <h1 id="hero-title" class="sr-only">
    NIVO limpieza profesional de casas, oficinas y empresas en Ibarra, Atuntaqui, Cotacachi y Otavalo
  </h1>
</section>
