---
import { site } from "../../data/siteContent";
---

<section class="content-section contact-section" id="contacto" aria-labelledby="contact-title" data-parallax-section>
  <div class="parallax-layer parallax-layer--panel">
    <div class="contact-card">
      <div>
        <span class="section-eyebrow">Contacto</span>
        <h2 id="contact-title">Cotiza tu limpieza en minutos.</h2>
        <p>
          Usa la cotización guiada para obtener un valor inicial y luego confirma
          los detalles por WhatsApp.
        </p>
      </div>

      <div class="contact-actions">
        <a class="button quote-cta" href="#cotizacion">
          Cotiza con nosotros
        </a>
        <a class="button button--light" href={site.contact.whatsappHref} target="_blank" rel="noreferrer">
          {site.contact.whatsappLabel}
        </a>
        <a class="button button--ghost contact-actions__email" href={`mailto:${site.contact.email}`}>
          {site.contact.email}
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const scrollToQuote = () => {
      const target = document.getElementById("cotizacion");

      if (!target) {
        return;
      }

      target.scrollIntoView({
        behavior: "smooth",
        block: "center",
        inline: "nearest",
      });
    };

    const handleAnchor = (event) => {
      const link = event.target.closest('a[href="#cotizacion"]');

      if (!link) {
        return;
      }

      event.preventDefault();
      scrollToQuote();
      history.replaceState(null, "", "#cotizacion");
    };

    document.addEventListener("click", handleAnchor);

    if (location.hash === "#cotizacion") {
      window.requestAnimationFrame(scrollToQuote);
    }
  })();
</script>
