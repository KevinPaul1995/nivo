---
import { coverageItems, serviceNotes } from "../../data/siteContent";
---

<section class="content-section coverage-section" id="calidad" aria-labelledby="coverage-title" data-parallax-section>
  <div class="section-grid section-grid--split coverage-layout">
    <div class="parallax-layer parallax-layer--copy">
      <div class="section-copy">
        <span class="section-eyebrow">Cobertura local</span>
        <h2 id="coverage-title">Limpieza profesional en Imbabura.</h2>
      </div>
    </div>

    <div class="parallax-layer parallax-layer--panel">
      <div class="coverage-panel" aria-label="Zonas de cobertura NIVO">
        {
          coverageItems.map((item) => (
            <article>
              <h3>{item.city}</h3>
            </article>
          ))
        }
      </div>
    </div>
  </div>

  <div class="standards-strip parallax-layer parallax-layer--quiet" aria-label="Diferenciales del servicio NIVO">
    {
      serviceNotes.map((item) => (
        <span>{item}</span>
      ))
    }
  </div>

  <button class="section-scroll-cue" type="button" data-scroll-next aria-label="Ir a la siguiente sección">
    <span></span>
  </button>
</section>
