---
import { services, serviceNotes } from "../../data/siteContent";
---

<section class="content-section services-section" id="servicios" aria-labelledby="services-title" data-parallax-section>
  <div class="parallax-layer parallax-layer--copy">
    <div class="section-heading section-heading--center">
      <span class="section-eyebrow" data-i18n="services.eyebrow">Casas · oficinas · empresas</span>
      <h2 id="services-title" data-i18n="services.title">Limpieza para tu espacio.</h2>
    </div>
  </div>

  <div class="parallax-layer parallax-layer--panel">
    <div class="services-grid">
      {
        services.map((service) => (
          <article class="service-card">
            <h3 data-i18n={`services.card.${service.title}.title`}>{service.title}</h3>
            <ul>
              {service.items.map((item) => (
                <li data-i18n={`services.item.${item}`}>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>

  <div class="service-note parallax-layer parallax-layer--quiet" aria-label="Modalidades de servicio">
    {
      serviceNotes.map((item) => (
        <span data-i18n={`service-note.${item}`}>{item}</span>
      ))
    }
  </div>

  <button class="section-scroll-cue" type="button" data-scroll-next aria-label="Ir a la siguiente sección">
    <span aria-hidden="true"></span>
  </button>
</section>
