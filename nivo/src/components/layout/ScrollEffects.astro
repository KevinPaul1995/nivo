<script is:inline>
  (() => {
    const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    const sections = Array.from(document.querySelectorAll("main > .content-section[data-parallax-section]"))
      .filter((section) => !section.closest(".hero"));

    const scrollToNextSection = (section) => {
      const nextSection = section?.nextElementSibling;

      if (!nextSection) {
        return;
      }

      nextSection.scrollIntoView({
        behavior: reduceMotionQuery.matches ? "auto" : "smooth",
        block: "start",
      });
    };

    document.addEventListener("click", (event) => {
      const cue = event.target.closest("[data-scroll-next]");

      if (!cue) {
        return;
      }

      const section = cue.closest("section");

      if (!section) {
        return;
      }

      event.preventDefault();

      if (section.classList.contains("hero")) {
        const heroEvent = new CustomEvent("nivo:hero-next", {
          cancelable: true,
        });

        document.dispatchEvent(heroEvent);

        if (heroEvent.defaultPrevented) {
          return;
        }
      }

      scrollToNextSection(section);
    });

    if (!sections.length || reduceMotionQuery.matches) {
      return;
    }

    let frame = 0;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const update = () => {
      frame = 0;

      const viewportHeight = window.visualViewport?.height || window.innerHeight || 1;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const progress = clamp((viewportHeight - rect.top) / (viewportHeight + rect.height), 0, 1);
        const centered = progress - 0.5;

        const compact = window.innerWidth < 760;
        const copyRange = compact ? -48 : -118;
        const panelRange = compact ? 42 : 96;
        const quietRange = compact ? -28 : -72;
        const rotationRange = compact ? 0 : 1.1;

        section.style.setProperty("--parallax-a", `${(centered * copyRange).toFixed(2)}px`);
        section.style.setProperty("--parallax-b", `${(centered * panelRange).toFixed(2)}px`);
        section.style.setProperty("--parallax-c", `${(centered * quietRange).toFixed(2)}px`);
        section.style.setProperty("--parallax-r", `${(centered * rotationRange).toFixed(3)}deg`);
        section.style.setProperty("--parallax-r-inverse", `${(centered * -rotationRange).toFixed(3)}deg`);
        section.style.setProperty("--section-progress", progress.toFixed(3));
      });
    };

    const requestUpdate = () => {
      if (frame) {
        return;
      }

      frame = window.requestAnimationFrame(update);
    };

    update();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    window.visualViewport?.addEventListener("resize", requestUpdate);
  })();
</script>
