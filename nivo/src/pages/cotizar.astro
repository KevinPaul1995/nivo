---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWizard from '../components/QuoteWizard.jsx';
---

<BaseLayout
  title="Cotizar limpieza | NIVO Servicios de limpieza en Imbabura"
  description="Cotiza servicios de limpieza para casas, departamentos, oficinas y locales en Ibarra, Otavalo, Atuntaqui, Cotacachi y otros sectores de Imbabura."
  canonical="https://nivolimpieza.com/cotizar"
>
  <main class="quote-page">
    <section class="quote-page-hero">
      <a class="quote-page-hero__back" href="/" data-i18n="quote-page.back">Volver al inicio</a>
      <span class="section-eyebrow" data-i18n="quote-page.eyebrow">Cotizador NIVO</span>
      <h1 data-i18n="quote-page.title">Calcula tu valor de limpieza paso a paso.</h1>
    </section>

    <QuoteWizard client:load />
  </main>
</BaseLayout>
